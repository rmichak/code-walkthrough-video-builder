# Node
node_modules/
npm-debug.log*

# Secrets — never commit
.env
.env.*
*.key

# Generated HyperFrames project artifacts (these are produced by the build, not source)
demo/
*-hyperframes/
/index.html
data.js
cc-data.js
# …but the skill's source composition shells are NOT generated — keep them.
!skills/**/index.html

# Generated audio / transcripts (regenerate with tts + transcribe)
audio/*.wav
audio/*.json
narration/

# Renders — keep these out of git; put curated samples in examples/ instead
renders/
*.mp4
!examples/**/*.mp4

# OS cruft
.DS_Store
Thumbs.db
